APP_NAME=Tythys API Revenue Guard
APP_VERSION=0.1.0
BACKEND_SERVICE_MODE=local-parity
INGEST_API_KEY=dev-ingest-key

# Local parity mode: run against Docker Postgres.
REQUIRE_DATABASE=true
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/revenue_guard

# Safe in parity mode if you want startup bootstrap for scratch DBs.
BOOTSTRAP_DB_SCHEMA=false

# Optional tuning.
REVENUE_VALUE_PER_SUCCESS_USD=0.02
ROLLUP_INTERVAL_SECONDS=30
