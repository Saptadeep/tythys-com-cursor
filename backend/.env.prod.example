APP_NAME=Tythys API Revenue Guard
APP_VERSION=0.1.0
BACKEND_SERVICE_MODE=production

# Required in production.
INGEST_API_KEY=replace-with-strong-secret
REQUIRE_DATABASE=true
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db-host:5432/revenue_guard

# Keep false in production; migrations should own schema updates.
BOOTSTRAP_DB_SCHEMA=false

# Optional tuning.
REVENUE_VALUE_PER_SUCCESS_USD=0.02
ROLLUP_INTERVAL_SECONDS=30
