APP_NAME=Tythys API Revenue Guard
APP_VERSION=0.1.0
BACKEND_SERVICE_MODE=demo
INGEST_API_KEY=dev-ingest-key

# Baseline example defaults to local quick mode (in-memory).
# See `.env.local.parity.example` and `.env.prod.example` for other profiles.
REQUIRE_DATABASE=false
DATABASE_URL=

# Dev-only; leave false in production.
BOOTSTRAP_DB_SCHEMA=false

# Optional tuning.
REVENUE_VALUE_PER_SUCCESS_USD=0.02
ROLLUP_INTERVAL_SECONDS=30
